{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LightRead 主窗口权限: SQLite 索引, 应用数据目录读写 (书籍文件), OPDS 网络请求, 系统对话框与外链",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/**"
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://**"
        },
        {
          "url": "http://**"
        }
      ]
    }
  ]
}