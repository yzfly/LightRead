{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LightRead",
  "version": "0.8.1",
  "identifier": "com.yzfly.lightread",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LightRead 轻阅",
        "width": 1180,
        "height": 780,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Reference",
    "shortDescription": "开源本地阅读器",
    "longDescription": "LightRead 轻阅：开源、本地优先的全格式电子书阅读器。支持 EPUB、MOBI、AZW3、FB2、CBZ、PDF、TXT、Markdown，藏书管理与 OPDS 开放书源。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}