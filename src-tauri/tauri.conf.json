{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LightRead",
  "version": "1.0.4",
  "identifier": "com.yzfly.lightread",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LightRead 轻阅",
        "width": 1180,
        "height": 780,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Reference",
    "shortDescription": "开源本地阅读器",
    "longDescription": "LightRead 轻阅：开源、本地优先的全格式电子书阅读器。支持 EPUB、MOBI、AZW3、FB2、CBZ、PDF、TXT、Markdown，藏书管理与 OPDS 开放书源。",
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF 文档",
        "role": "Viewer",
        "mimeType": "application/pdf",
        "rank": "Default"
      },
      {
        "ext": ["epub"],
        "name": "EPUB eBook",
        "description": "EPUB 电子书",
        "role": "Viewer",
        "mimeType": "application/epub+zip",
        "rank": "Default"
      },
      {
        "ext": ["mobi"],
        "name": "Mobipocket eBook",
        "description": "MOBI 电子书",
        "role": "Viewer",
        "mimeType": "application/x-mobipocket-ebook",
        "rank": "Default"
      },
      {
        "ext": ["azw", "azw3"],
        "name": "Kindle eBook",
        "description": "Kindle 电子书",
        "role": "Viewer",
        "mimeType": "application/vnd.amazon.ebook",
        "rank": "Default"
      },
      {
        "ext": ["fb2", "fbz", "fb2.zip"],
        "name": "FictionBook eBook",
        "description": "FictionBook 电子书",
        "role": "Viewer",
        "mimeType": "application/x-fictionbook+xml",
        "rank": "Default"
      },
      {
        "ext": ["cbz"],
        "name": "CBZ Comic Book",
        "description": "CBZ 漫画",
        "role": "Viewer",
        "mimeType": "application/vnd.comicbook+zip",
        "rank": "Default"
      },
      {
        "ext": ["cbr"],
        "name": "CBR Comic Book",
        "description": "CBR 漫画",
        "role": "Viewer",
        "mimeType": "application/vnd.comicbook-rar",
        "rank": "Default"
      },
      {
        "ext": ["djvu", "djv"],
        "name": "DjVu Document",
        "description": "DjVu 文档",
        "role": "Viewer",
        "rank": "Default"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text Document",
        "description": "纯文本文档",
        "role": "Viewer",
        "mimeType": "text/plain",
        "rank": "Default"
      },
      {
        "ext": ["html", "htm"],
        "name": "HTML Document",
        "description": "HTML 文档",
        "role": "Viewer",
        "mimeType": "text/html",
        "rank": "Default"
      },
      {
        "ext": ["xhtml"],
        "name": "XHTML Document",
        "description": "XHTML 文档",
        "role": "Viewer",
        "mimeType": "application/xhtml+xml",
        "rank": "Default"
      },
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown 文档",
        "role": "Viewer",
        "mimeType": "text/markdown",
        "rank": "Default"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
